.root {
    padding: 10px;
    flex-direction: column;
    flex-grow: 1;
    align-items: center;
}

/* =================== SECTION ======================= */

.section {
    align-items: center;
    width: 92%;
}

.section-waveform-view {
    height: 200px;
}

.section-flux-view {
    margin-top: 20px;
    height: 200px;
    border-radius: 10px;
    background-color: #171725;
}

/* ================== CONTAINER ======================= */

.container {
    flex-grow: 1;
    align-self: stretch;
}

.container-waveform {
    height: 200px;
}

/* =================== BUTTON ======================= */

.button {
    background-color: #2a72ff;
    color: #e1e1e1;
    border-radius: 8px;
    padding: 8px 12px;
    margin-top: 10px;
    width: 100%;
}

.button:hover {
    background-color: #1f5bd1;
}

.button-remove-audio {
    background-color: #852421;
}

.button-remove-audio:hover {
    background-color: #55100f;
}

/* ===================== LABEL ======================= */

.label {
    font-size: 24px;
    -unity-font-style: bold;
}

.label-header {
    margin-bottom: 6px;
}

.label-path {
    font-size: 12px;
    color: #999;
    margin-top: 10px;
}

/* ================== WAVEFORM-VIEW ======================= */

.waveform {
    flex-grow: 1;
    width: 100%;
    height: 100%;
}

/* ==================== FLUX VIEWER ======================= */

.flux-graph {
    flex-grow: 1;
    width: 100%;
    height: 100%;
}