# This .gitignore file should be placed at the root of your Unity project directory.
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
[Mm]emoryCaptures/

# Unity generated File ID compatibility file
.-[Mm]eta/

# OSX
.DS_store
.DS_Store?
Icon?

# Visual Studio cache files
.vs/
.suo
.user
.lock
/*.csproj
/*.unityproj
/*.sln
/*.asln
.unityuftd/

# Rider
.idea/
*.iml
*.ipr
*.iws

# Autogenerated VS/MD/MonoDevelop solution and project files
ExportedObj/
.consulo/

# Unity-generated text meta files
*.pidb
*.booproj
*.svd
*.rsp
*.core
*.dll.config
/*.meta
# Unity-generated dll files
/*.dll
# Unity-generated pdb files
/*.pdb
# Unity-generated executable files
/*.exe
/*.stackdump

# Blender
*.blend1
*.blend1.meta

/Prompts/
